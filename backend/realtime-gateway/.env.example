NODE_ENV=development
PORT=8080

OPENAI_API_KEY=sk-your-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_REALTIME_MODEL=gpt-realtime
OPENAI_REALTIME_VOICE=marin
OPENAI_HTTP_TIMEOUT_MS=20000

SESSION_IDLE_TIMEOUT_MS=120000
SESSION_SWEEP_INTERVAL_MS=30000
SDP_MAX_BYTES=200000

# --- JobAI REST (список/деталь интервью, PATCH статуса) — см. docs/JOBAI_PARTNER_CREDENTIALS.md ---
JOBAI_API_BASE_URL=https://back.dev.job-ai.ru
# none | bearer | basic
JOBAI_API_AUTH_MODE=bearer
JOBAI_API_TOKEN=
# JOBAI_API_AUTH_MODE=basic
# JOBAI_API_BASIC_USER=
# JOBAI_API_BASIC_PASSWORD=

# Опционально: секрет для POST /webhooks/jobai/interviews на нашем gateway
# JOBAI_INGEST_SECRET=

JOBAI_WEBHOOK_ENABLED=false
JOBAI_WEBHOOK_URL=https://jobai.example.com/webhooks/meeting-status
JOBAI_WEBHOOK_SECRET=replace-with-long-random-secret
JOBAI_WEBHOOK_DISPATCH_INTERVAL_MS=1000
JOBAI_WEBHOOK_MAX_ATTEMPTS=4
