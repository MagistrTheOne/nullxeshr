NODE_ENV=development
PORT=8080

OPENAI_API_KEY=sk-your-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_REALTIME_MODEL=gpt-realtime
OPENAI_REALTIME_VOICE=marin
OPENAI_HTTP_TIMEOUT_MS=20000

SESSION_IDLE_TIMEOUT_MS=120000
SESSION_SWEEP_INTERVAL_MS=30000
SDP_MAX_BYTES=200000

JOBAI_WEBHOOK_ENABLED=false
JOBAI_WEBHOOK_URL=https://jobai.example.com/webhooks/meeting-status
JOBAI_WEBHOOK_SECRET=replace-with-long-random-secret
JOBAI_WEBHOOK_DISPATCH_INTERVAL_MS=1000
JOBAI_WEBHOOK_MAX_ATTEMPTS=4
